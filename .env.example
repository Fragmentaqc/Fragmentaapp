# URL publique du projet Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clé publique/publishable Supabase — ne jamais placer la service_role ici
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Jeton public Mapbox restreint aux API de navigation utilisées par l’application
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-public-mapbox-token
